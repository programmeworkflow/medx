{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "functions": {
    "api/esocial/sync.ts": { "maxDuration": 60 },
    "api/esocial/sync-next.ts": { "maxDuration": 60 },
    "api/eso/[action].ts": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/eso/sync-companies",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/esocial/sync-next",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/contaazul/refresh-session",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/contaazul/oauth-refresh",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/contaazul/health-check",
      "schedule": "7 11 * * 1"
    }
  ]
}
